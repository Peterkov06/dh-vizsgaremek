	indexes {
		(PreferenceGroupId) [ name: 'IX_Preferences_PreferenceGroupId' ]
	}
}

Table RefreshTokens [headercolor: #175e7a] {
	Id integer [ pk, increment, not null ]
	Token text [ not null ]
