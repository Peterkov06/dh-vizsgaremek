	LoginProvider varchar(256) [ pk, not null ]
	Name varchar(256) [ pk, not null ]
	Value text
}

Table AspNetUsers [headercolor: #175e7a] {
	Id varchar(256) [ pk, not null ]
	FullName varchar(256) [ not null ]
	DateOfBirth date [ not null ]
	Address text [ not null ]
	UserName varchar(256)
	NormalizedUserName varchar(256)
	Email varchar(256)
	NormalizedEmail varchar(256)
	EmailConfirmed boolean [ not null ]
	PasswordHash text
	SecurityStamp text
	ConcurrencyStamp text
	PhoneNumber varchar(50)
	PhoneNumberConfirmed boolean [ not null ]
	TwoFactorEnabled boolean [ not null ]
	LockoutEnd date
	LockoutEnabled boolean [ not null ]
	AccessFailedCount integer [ not null ]
	Nickname varchar(256)
	Introduction text
	ProfilePicUrl text
	CityId integer [ not null ]
	PostalCode varchar(20) [ not null ]
}

Table Cities [headercolor: #175e7a] {
	Id integer [ pk, increment, not null ]
	CityName varchar(256) [ not null ]
	PostalCode varchar(4) [ not null ]
}

Table PreferenceGroups [headercolor: #175e7a] {
	Id integer [ pk, increment, not null ]
	Name varchar(256) [ not null ]
}

Table Preferences [headercolor: #175e7a] {
	Id integer [ pk, increment, not null ]
	Name varchar(256) [ not null ]
